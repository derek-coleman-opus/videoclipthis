# --- Core (required to run) ---
DATABASE_URL=                      # Neon Postgres connection string
ADMIN_PASSWORD=changeme            # Basic-auth password for the admin panel
CRON_SECRET=                       # Vercel sends this as the cron Authorization bearer

# There is no mock mode: every run hits the real services below and aborts loudly if a
# required key is missing. The autonomy=review gate (Settings) is the safety net — in review
# mode the pipeline discovers/scores/clips but never posts until you approve in the admin.

# --- Claude (scoring + moment curation) — required ---
ANTHROPIC_API_KEY=

# --- OpusClip (clip / reframe / caption / export) — required ---
OPUSCLIP_API_KEY=                  # confirm an agent-reachable tier with Product
OPUSCLIP_API_BASE=https://api.opus.pro

# --- YouTube Data API (source ingest + transcripts) — required ---
YOUTUBE_API_KEY=

# --- X / Twitter API v2 (posting + summon) — needs the "Automated" account label ---
# Required to publish (autonomy=auto or approving a clip). X_BEARER_TOKEN is for reads and
# is HARD-REQUIRED by the summon (5-min) and feedback (hourly) crons — without it those runs
# fail. Provision on usage-based (pay-as-you-go) pricing with a spend cap.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# --- XBot: personal-account growth bot (separate X developer app from the clip bot!) ---
# Create the app under YOUR personal X account; Basic tier (~$200/mo) is needed for tweet
# search (discovery) and enough write volume. OAuth 1.0a Read & Write tokens, like above.
# Without these the XBot runs in drafting-only mode (queue + Claude drafts still work).
XBOT_API_KEY=
XBOT_API_SECRET=
XBOT_ACCESS_TOKEN=
XBOT_ACCESS_SECRET=
XBOT_BEARER_TOKEN=

# --- Hardening + supply knobs (optional; defaults in lib/pipeline/config.ts) ---
COST_CAP_USD=5                     # stop submitting renders once today's recorded clip spend hits this
MAX_CLIPS_PER_RUN=25               # max render submissions per scout run
MAX_CONCURRENT_RENDERS=3           # OpusClip concurrent-project budget (plan cap minus headroom)
MAX_AGE_HOURS=168                  # only ingest videos published in the last N hours
FIGURE_SEARCH_INTERVAL_H=6         # per-figure YouTube searches cost 100 quota units — run every N hours
RENDER_TIMEOUT_H=2                 # fail a render this long after SUBMISSION with no clips
MIN_CLIP_POST_GAP_MIN=20           # minimum minutes between consecutive auto-posted clips
# Daily auto-post volume cap lives in admin Settings (dailyClipCap), not env.
