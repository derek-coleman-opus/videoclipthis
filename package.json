{
  "name": "videoclipthis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "scout": "tsx --env-file=.env scripts/run.ts scout",
    "summon": "tsx --env-file=.env scripts/run.ts summon",
    "feedback": "tsx --env-file=.env scripts/run.ts feedback",
    "pipeline": "tsx --env-file=.env scripts/run.ts pipeline"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "twitter-api-v2": "^1.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "comment_optional_deps": "Add when wiring real clients (M-next): @anthropic-ai/sdk, twitter-api-v2. YouTube + OpusClip are called via fetch.",
  "engines": { "node": ">=20" }
}
